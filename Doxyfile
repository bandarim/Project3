# Doxyfile for Load Balancer Simulation Project

# --- Project Related Settings ---
PROJECT_NAME           = "Load Balancer Simulator"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "A high-performance C++ simulation of request distribution, autoscaling, and IP filtering."
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES

# --- Input Settings ---
# This will scan all .h and .cpp files in the current directory
INPUT                  = .
FILE_PATTERNS          = *.h \
                         *.cpp \
                         *.hpp
RECURSIVE              = YES
EXCLUDE                = 

# --- Extraction Settings ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

# --- Build Settings ---
# Includes nice source code browser linked to documentation
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# --- HTML Output Settings ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
# Set to YES for a tree-view navigation pane on the left
GENERATE_TREEVIEW      = YES

# --- LaTeX/PDF Output Settings ---
GENERATE_LATEX         = NO

# --- Diagram Settings (Requires Graphviz/dot) ---
# If you don't have Graphviz installed, set HAVE_DOT to NO
HAVE_DOT               = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

# --- Formatting Settings ---
# Recognizes the Javadoc-style tags used in your headers (@brief, @param, etc.)
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
TAB_SIZE               = 4